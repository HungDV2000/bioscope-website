# ── Database (PostgreSQL 16) ───────────────────────────────
DATABASE_URI=postgres://dvcms:dvcms@localhost:5432/dvcms

# ── Payload ────────────────────────────────────────────────
# Generate a long random string (>= 32 chars) for production.
PAYLOAD_SECRET=please-change-this-to-a-long-random-secret

# ── Server ─────────────────────────────────────────────────
PORT=3001
# Public URL of this CMS (used by admin + CORS).
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3001

# ── Frontend integration (revalidation) ────────────────────
# Disabled until the frontend is wired. Leave blank to skip revalidate calls.
FRONTEND_URL=
REVALIDATE_SECRET=please-change-this-revalidate-secret

# ── B2B portal ─────────────────────────────────────────────
B2B_COOKIE=bio-token
