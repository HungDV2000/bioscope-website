{
  "name": "dv-cms",
  "private": true,
  "version": "0.1.0",
  "description": "DeepViewJSC headless CMS platform — reusable core + installable modules (Payload 3), deployable via core-cms",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "cms:dev": "pnpm --filter @dv/core-cms dev",
    "cms:devsafe": "pnpm --filter @dv/core-cms devsafe",
    "cms:seed": "pnpm --filter @dv/core-cms seed",
    "cms:migrate": "pnpm --filter @dv/core-cms migrate",
    "cms:migrate:create": "pnpm --filter @dv/core-cms migrate:create",
    "cms:types": "pnpm --filter @dv/core-cms generate:types",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "5.9.3"
  }
}
