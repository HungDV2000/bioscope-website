{
  "name": "dv-cms",
  "private": true,
  "version": "0.1.0",
  "description": "DeepViewJSC headless CMS platform — reusable core + installable modules (Payload 3), deployable via core-cms",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "cms:dev": "pnpm --filter @dv/core-cms dev",
    "cms:devsafe": "pnpm --filter @dv/core-cms devsafe",
    "cms:seed": "pnpm --filter @dv/core-cms seed",
    "cms:migrate": "pnpm --filter @dv/core-cms migrate",
    "cms:migrate:create": "pnpm --filter @dv/core-cms migrate:create",
    "cms:lang:sync": "pnpm --filter @dv/core-cms lang:sync",
    "cms:ct:sync": "pnpm --filter @dv/core-cms ct:sync",
    "cms:ct:apply": "pnpm --filter @dv/core-cms ct:apply",
    "cms:types": "pnpm --filter @dv/core-cms generate:types",
    "migrate": "pnpm cms:migrate",
    "lang:sync": "pnpm cms:lang:sync",
    "devsafe": "pnpm cms:devsafe",
    "fe:dev": "pnpm --filter @dv/bioscope-frontend dev",
    "fe:build": "pnpm --filter @dv/bioscope-frontend build",
    "fe:start": "pnpm --filter @dv/bioscope-frontend start",
    "start": "pnpm --filter @dv/bioscope-frontend start",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "5.9.3"
  },
  "pnpm": {
    "patchedDependencies": {
      "@payloadcms/next@3.85.1": "patches/@payloadcms__next@3.85.1.patch"
    }
  }
}
