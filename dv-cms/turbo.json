{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "DATABASE_URI",
    "PAYLOAD_SECRET",
    "FRONTEND_URL",
    "REVALIDATE_SECRET",
    "B2B_COOKIE",
    "NODE_ENV",
    "PORT"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "generate:types": {
      "cache": false
    }
  }
}
