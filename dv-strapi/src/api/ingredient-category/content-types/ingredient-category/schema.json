{
  "kind": "collectionType",
  "collectionName": "ingredient_categories",
  "info": {
    "singularName": "ingredient-category",
    "pluralName": "ingredient-categories",
    "displayName": "Ingredient Category"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "slug": {
      "type": "uid",
      "targetField": "name"
    },
    "scope": {
      "type": "enumeration",
      "enum": [
        "supplement",
        "cosmetic",
        "both"
      ],
      "default": "both"
    }
  }
}
